# Coinbase Advanced Trade API Credentials
# 
# Copy this file to .env and fill in your actual credentials
# 
# ⚠️ SECURITY WARNING: Never commit .env to version control!
# Add .env to .gitignore immediately.
#

# Advanced Trade API (Recommended)
# Get these from: https://coinbase.com/settings/api
COINBASE_KEY_NAME=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
COINBASE_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\n[YOUR_PRIVATE_KEY_HERE]\n-----END EC PRIVATE KEY-----

# Legacy REST API (Optional, for backwards compatibility)
COINBASE_API_KEY=your-api-key-here
COINBASE_API_SECRET=your-api-secret-here
