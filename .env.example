# InvestPro Environment Template
# Copy this file to .env and set only the values you use.
#
# SECURITY WARNING:
# - Never commit .env to version control
# - Use read-only or least-privilege API keys where possible

# ==================== Runtime Profile ====================
APP_ENV=development
APP_DEBUG=true
APP_STRICT_STARTUP_VALIDATION=false
APP_HEARTBEAT_STALE_SECONDS=120

# PAPER (default) or LIVE
DEFAULT_ACCOUNT_MODE=PAPER

# Optional JVM/system profile override used by app startup logic
# INVESTPRO_PROFILE=default

# ==================== Feature Toggles ====================
# Enable only exchanges you plan to use live.
ENABLE_COINBASE=true
ENABLE_BINANCE=false
ENABLE_OANDA=false

# Optional external integrations
ENABLE_TELEGRAM=false
ENABLE_OPENAI=false

# ==================== Coinbase Advanced Trade ====================
# Get these from: https://coinbase.com/settings/api
COINBASE_KEY_NAME=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
COINBASE_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\n[YOUR_PRIVATE_KEY_HERE]\n-----END EC PRIVATE KEY-----

# Legacy Coinbase REST (optional/backward compatibility)
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ==================== Binance ====================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ==================== OANDA ====================
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# ==================== Telegram ====================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==================== OpenAI ====================
OPENAI_API_KEY=
