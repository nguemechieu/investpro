<configuration>
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Activity Monitor Appender - captures logs for dashboard display -->
    <appender name="activityMonitor" class="org.investpro.monitoring.ActivityLogAppender">
    </appender>

    <!-- Suppress noisy JavaFX logs -->
    <logger name="javafx" level="WARN"/>
    <logger name="com.sun.javafx" level="WARN"/>
    <logger name="javafx.scene.control.skin" level="ERROR"/>
    
    <!-- Suppress JavaFX WebKit media player errors (YouTube codec issues) -->
    <logger name="com.sun.javafx.webkit.prism" level="ERROR"/>

    <!-- Suppress database connection logs -->
    <logger name="org.sqlite" level="WARN"/>
    
    <!-- Suppress SLF4J initialization -->
    <logger name="org.slf4j" level="ERROR"/>

    <!-- Root logger set to INFO level -->
    <root level="INFO">
        <appender-ref ref="console"/>
        <appender-ref ref="activityMonitor"/>
    </root>
</configuration>

